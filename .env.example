# Database (choose one)
DATABASE_URL=file:./open-notehub.db
# DATABASE_URL=libsql://[db-name]-[org].turso.io?authToken=[token]

# Auth
AUTH_PASSWORD=your-reading-password-here
AUTH_SECRET=your-32-char-secret-for-jwt-signing

# Agent ingestion
AGENT_API_KEY=your-agent-api-key-here

# LLM provider
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=glm-4.7
LLM_MODEL_FALLBACKS=glm-4.5-air,glm-4.6

# Search provider
ANSPIRE_API_KEY=your-anspire-api-key-here

# Optional
NEXT_PUBLIC_SITE_TITLE=Open NoteHub
