# Database (choose one)
DATABASE_URL=file:./data/open-notehub.db
# DATABASE_URL=libsql://[db-name]-[org].turso.io?authToken=[token]

# Auth
AUTH_PASSWORD=your-reading-password-here
AUTH_SECRET=your-32-char-secret-for-jwt-signing

# Agent ingestion
AGENT_API_KEY=your-agent-api-key-here

# Optional local browser-backed web-access
# WEB_ACCESS_BROWSER_USE_PATH=.\\.venv\\Scripts\\browser-use.exe
# WEB_ACCESS_RENDERER_TIMEOUT_MS=30000
# WEB_ACCESS_RENDERER_SESSION=web-access-rendered
# WEB_ACCESS_BROWSER_PROFILE=Default
# WEB_ACCESS_BROWSER_SESSION_TIMEOUT_MS=45000
# WEB_ACCESS_BROWSER_SESSION=web-access-browser-session

# Optional remote web-access bridges
# WEB_ACCESS_BROWSER_SESSION_ENDPOINT=http://127.0.0.1:8787/browser-session
# WEB_ACCESS_BROWSER_SESSION_TOKEN=replace-me
# WEB_ACCESS_RENDERER_ENDPOINT=http://127.0.0.1:8787/rendered-page
# WEB_ACCESS_RENDERER_TOKEN=replace-me

# LLM provider
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=glm-4.7
LLM_MODEL_FALLBACKS=glm-4.5-air,glm-4.6

# Search provider
ANSPIRE_API_KEY=your-anspire-api-key-here

# Optional
NEXT_PUBLIC_SITE_TITLE=Open NoteHub
